# Neo4j connection used by graph scripts, snapshot generation, and the server.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-local-password

# Extraction/narration provider: openrouter, openai, or gemini.
LLM_PROVIDER=openrouter

# OpenRouter (used for bulk offline extraction when LLM_PROVIDER=openrouter).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# OpenAI (set LLM_PROVIDER=openai to run extraction/narration on GPT-5.6).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Gemini (used when LLM_PROVIDER=gemini).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local Node/Vite server port.
PORT=5173
